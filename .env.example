# APP
APP_ENV=development
APP_SECRET_KEY=change-me-64-char-random-string-here-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APP_NAME=EduSaaS
APP_VERSION=3.0.0

# DATABASE
DATABASE_URL=postgresql+asyncpg://edusaas:edusaas_pass@localhost:5432/edusaas
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# REDIS
REDIS_URL=redis://localhost:6379/0

# TELEGRAM
BOT_TOKEN=your_bot_token_here
BOT_WEBHOOK_URL=https://api.edusaas.uz/webhook/bot

# JWT
JWT_SECRET=change-me-64-char-random-string-here-yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# CLICK PAYMENT
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# YANDEX S3 STORAGE
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=edusaas-files
S3_REGION=ru-central1

# MONITORING
SENTRY_DSN=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://edusaas.uz
